{
  "name": "battle-ship",
  "version": "1.0.0",
  "description": "Webpack template to start e new web-app using HTML-CSS-JS with webpack",
  "main": "webpack.common.js",
  "scripts": {
    "build": "webpack --config webpack.prod.js",
    "dev": "webpack serve --config webpack.dev.js",
    "deploy": "git subtree push --prefix dist origin gh-pages",
    "lint": "eslint src/",
    "format": "prettier --write \"src/**/*.{js,jsx,css,html}\"",
    "test": "jest",
    "test:watch": "jest --watch"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/emanuele-d94/battle-ship.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/emanuele-d94/battle-ship/issues"
  },
  "homepage": "https://github.com/emanuele-d94/battle-ship#readme",
  "devDependencies": {
    "@babel/preset-env": "^7.29.7",
    "@eslint/js": "^10.0.1",
    "css-loader": "^7.1.4",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.6.0",
    "html-loader": "^5.1.0",
    "html-webpack-plugin": "^5.6.7",
    "jest": "^30.4.2",
    "prettier": "^3.8.4",
    "style-loader": "^4.0.0",
    "webpack": "^5.107.2",
    "webpack-cli": "^7.0.3",
    "webpack-dev-server": "^5.2.5",
    "webpack-merge": "^6.0.1"
  }
}
